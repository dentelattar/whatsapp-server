# Port the server listens on
PORT=3000

# Chromium/Chrome path (leave empty for auto-detect or Railway Dockerfile default)
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

# Auth data directory (relative paths are under /app)
WWEBJS_AUTH_PATH=./.wwebjs_auth

# Comma-separated list of allowed user IDs
# Leave empty to allow any userId
ALLOWED_USERS=

# API key for authenticating requests from SuperDent (optional)
# If set, requests must include x-api-key header
API_KEY=
