# Port the server listens on
PORT=3000

# Chromium/Chrome path (leave empty for auto-detect or Railway Dockerfile default)
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

# Auth data directory (relative paths are under /app)
WWEBJS_AUTH_PATH=./.wwebjs_auth

# Comma-separated list of allowed user IDs
# Leave empty to allow any userId
ALLOWED_USERS=

# API key for authenticating requests from SuperDent (optional)
# If set, requests must include x-api-key header
API_KEY=

# Firebase Admin SDK service account (base64-encoded JSON)
# Required for persistent WhatsApp sessions across Railway restarts
# Without this, sessions are lost on every deploy/restart
# Encode: cat dentalapps-beaf7-firebase-adminsdk-ufja3-b81953ae45.json | base64 -w0
FIREBASE_SERVICE_ACCOUNT=
